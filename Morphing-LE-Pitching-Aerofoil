            real theta = -PitchAmpRad * sin(2 * M_PI * Freq_Pitching * (time - FTT));
            real x_rot, y_rot;
            rotate_about_center(x_local, y_local, theta, &x_rot, &y_rot);

            NODE_X(node_p) = x_rot;
            NODE_Y(node_p) = y_rot;
			}
        }
    }
    end_f_loop(f, tf);
}
