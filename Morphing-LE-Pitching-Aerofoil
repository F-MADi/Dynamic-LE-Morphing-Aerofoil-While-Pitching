                real cofp = 2 * sqrt(x_s_le * x_s_le + yLE * yLE) / denom;
                real dyc_dx = cofp * (tan(W_le) / (x_s_le * x_s_le)) * 2 * (x_s_le - x_org);

               x_local = xc_wang + (thickness / sqrt(1 + dyc_dx * dyc_dx)) * dyc_dx;
               y_local = yc_wang - thickness / sqrt(1 + dyc_dx * dyc_dx);


                //x_local = x_org;
